---
import Layout from '../layouts/Layout.astro';
import pengaturanBeranda from '../content/pengaturanBeranda/data.json';

const slideshowImages = pengaturanBeranda.slideshow || [];
---

<Layout title="Beranda - MTQ Tarbiyah Sunnah">
<main class="flex-grow pt-[80px]">
<!-- Hero Section -->
<section class="relative w-full h-[600px] md:h-[700px] overflow-hidden group">
<!-- Slider Images -->
<div class="w-full h-full relative" id="hero-slider">
{slideshowImages.map((src, index) => (
<div class={`absolute inset-0 transition-opacity duration-1000 ease-in-out slider-slide ${index === 0 ? 'opacity-100' : 'opacity-0'}`}>
<img alt={`Slideshow image ${index + 1}`} class="w-full h-full object-cover" src={src}/>
</div>
))}
</div>
<!-- Overlay Content -->
<div class="absolute inset-0 flex items-center justify-center z-10 px-margin-mobile md:px-margin-desktop">
<div class="bg-black/50 backdrop-blur-md p-lg md:p-xl rounded-2xl max-w-4xl text-center border border-white/20">
<h1 class="font-display-lg text-display-lg text-white mb-md drop-shadow-lg">Mendidik Generasi Qur’ani, Berakidah Lurus, Beradab, dan Mandiri</h1>
<p class="font-body-lg text-body-lg text-white/90 mb-lg drop-shadow">Ma’had Tahfizhul Qur’an Tarbiyah Sunnah adalah lembaga pendidikan jenjang SMP dan SMA khusus putra yang memadukan tahfizh Al-Qur’an, ilmu diniyah, bahasa Arab, akademik formal, dan pembinaan karakter Islami dalam lingkungan asrama yang kondusif.</p>
<div class="flex flex-wrap gap-sm justify-center">
<a href="/spmb" class="bg-secondary text-on-secondary px-lg py-sm rounded font-label-lg text-label-lg hover:bg-secondary-container hover:text-on-secondary-container transition-all shadow-[0px_4px_20px_rgba(149,74,0,0.4)]">Daftar SPMB</a>
<a href="/program/smp" class="bg-primary text-on-primary px-lg py-sm rounded font-label-lg text-label-lg hover:bg-primary-container hover:text-on-primary-container transition-all shadow-[0px_4px_20px_rgba(70,104,54,0.4)]">Lihat Program</a>
<a href="http://wa.me/6281210001476" target="_blank" rel="noopener noreferrer" class="border border-white text-white px-lg py-sm rounded font-label-lg text-label-lg hover:bg-white/10 transition-all">Hubungi Admin</a>
</div>
</div>
</div>
<!-- Arrows -->
<button class="absolute left-4 top-1/2 -translate-y-1/2 z-20 bg-black/30 hover:bg-black/50 text-white p-2 rounded-full backdrop-blur-sm transition-all opacity-0 group-hover:opacity-100 focus:opacity-100" id="btn-prev">
<span class="material-symbols-outlined text-3xl">chevron_left</span>
</button>
<button class="absolute right-4 top-1/2 -translate-y-1/2 z-20 bg-black/30 hover:bg-black/50 text-white p-2 rounded-full backdrop-blur-sm transition-all opacity-0 group-hover:opacity-100 focus:opacity-100" id="btn-next">
<span class="material-symbols-outlined text-3xl">chevron_right</span>
</button>
<!-- Dots -->
<div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex gap-2">
{slideshowImages.map((_, index) => (
<button class={`w-3 h-3 rounded-full transition-all slider-dot ${index === 0 ? 'bg-white' : 'bg-white/50 hover:bg-white/80'}`} data-index={index}></button>
))}
</div>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        let currentSlide = 0;
        const slides = document.querySelectorAll('.slider-slide');
        const dots = document.querySelectorAll('.slider-dot');
        const btnNext = document.getElementById('btn-next');
        const btnPrev = document.getElementById('btn-prev');

        if (!slides.length) return;
        
        function updateSlider() {
        slides.forEach((slide, index) => {
            if (index === currentSlide) {
            slide.classList.remove('opacity-0');
            slide.classList.add('opacity-100');
            dots[index].classList.remove('bg-white/50');
            dots[index].classList.add('bg-white');
            } else {
            slide.classList.remove('opacity-100');
            slide.classList.add('opacity-0');
            dots[index].classList.remove('bg-white');
            dots[index].classList.add('bg-white/50');
            }
        });
        }

        function nextSlide() {
            currentSlide = (currentSlide + 1) % slides.length;
            updateSlider();
        }

        function prevSlide() {
            currentSlide = (currentSlide - 1 + slides.length) % slides.length;
            updateSlider();
        }

        if(btnNext) btnNext.addEventListener('click', nextSlide);
        if(btnPrev) btnPrev.addEventListener('click', prevSlide);
        
        dots.forEach(dot => {
            dot.addEventListener('click', (e) => {
                const index = parseInt((e.target as HTMLElement).getAttribute('data-index') || '0');
                currentSlide = index;
                updateSlider();
            });
        });
        
        // Auto advance slides every 5 seconds
        setInterval(nextSlide, 5000);
    });
</script>
</section>
<!-- Trust Bar -->
<section class="py-xl px-margin-mobile md:px-margin-desktop bg-surface-container-lowest">
<div class="max-w-5xl mx-auto bg-primary text-on-primary rounded-xl p-xl text-center shadow-[0px_4px_20px_rgba(70,104,54,0.15)] relative overflow-hidden pattern-overlay-white">
<span class="material-symbols-outlined text-display-lg opacity-20 absolute top-md left-md">format_quote</span>
<span class="material-symbols-outlined text-display-lg opacity-20 absolute bottom-md right-md">format_quote</span>
<h2 class="font-headline-lg text-headline-lg mb-md relative z-10 text-tertiary-fixed">Visi Ma'had</h2>
