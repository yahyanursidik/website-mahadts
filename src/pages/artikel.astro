---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('artikel');
const sortedArticles = allArticles.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

// Featured is the newest
const featuredArticle = sortedArticles[0];
const regularArticles = sortedArticles.slice(1);
---

<Layout title="Artikel - MTQ Tarbiyah Sunnah">
<main class="flex-grow w-full max-w-7xl mx-auto px-margin-mobile md:px-margin-desktop py-xl grid grid-cols-1 md:grid-cols-12 gap-gutter islamic-pattern">
<!-- Page Header -->
<div class="col-span-1 md:col-span-12 mb-lg text-center">
<h1 class="font-display-lg text-display-lg text-primary mb-sm">Artikel &amp; Wawasan</h1>
<p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto">Kumpulan tulisan inspiratif, panduan adab, parenting islami, dan informasi terkini seputar Ma'had Tahfizhul Qur'an Tarbiyah Sunnah.</p>
</div>
<!-- Sidebar (Search & Categories) - Desktop: Col 1-3, Mobile: Top -->
<aside class="col-span-1 md:col-span-3 space-y-lg order-2 md:order-1">
<!-- Search -->
<div class="bg-surface-container-lowest p-md rounded-xl border border-surface-variant shadow-sm">
<h3 class="font-headline-md text-headline-md text-primary mb-sm flex items-center gap-2">
<span class="material-symbols-outlined">search</span> Pencarian
</h3>
<div class="relative">
<input class="w-full pl-10 pr-4 py-2 rounded-lg border border-outline-variant focus:border-primary focus:ring-2 focus:ring-primary-fixed-dim outline-none transition-all font-body-sm text-body-sm bg-surface-bright text-on-surface" placeholder="Cari artikel..." type="text"/>
<span class="material-symbols-outlined absolute left-3 top-2.5 text-outline text-[20px]">search</span>
</div>
</div>
<!-- Categories -->
<div class="bg-surface-container-lowest p-md rounded-xl border border-surface-variant shadow-sm">
<h3 class="font-headline-md text-headline-md text-primary mb-md flex items-center gap-2">
<span class="material-symbols-outlined">category</span> Kategori
</h3>
<ul class="space-y-3">
<li class="">
<a class="flex justify-between items-center group" href="#">
<span class="font-body-md text-body-md text-on-surface group-hover:text-primary transition-colors">Tahfizh</span>
<span class="bg-surface-container-low text-primary font-label-sm text-label-sm px-2 py-1 rounded-full group-hover:bg-primary-fixed transition-colors">12</span>
</a>
</li>
<li class="">
<a class="flex justify-between items-center group" href="#">
<span class="font-body-md text-body-md text-on-surface group-hover:text-primary transition-colors">Adab</span>
<span class="bg-surface-container-low text-primary font-label-sm text-label-sm px-2 py-1 rounded-full group-hover:bg-primary-fixed transition-colors">8</span>
</a>
</li>
<li class="">
<a class="flex justify-between items-center group" href="#">
<span class="font-body-md text-body-md text-on-surface group-hover:text-primary transition-colors">Parenting</span>
<span class="bg-surface-container-low text-primary font-label-sm text-label-sm px-2 py-1 rounded-full group-hover:bg-primary-fixed transition-colors">15</span>
</a>
</li>
<li class="">
<a class="flex justify-between items-center group" href="#">
<span class="font-body-md text-body-md text-primary font-medium transition-colors">Info Ma'had</span>
<span class="bg-primary text-on-primary font-label-sm text-label-sm px-2 py-1 rounded-full transition-colors">5</span>
</a>
</li>
</ul>
</div>
<div class="bg-surface-container-lowest p-md rounded-xl border border-surface-variant shadow-sm space-y-4"><div class="flex justify-center mb-2"><img alt="Logo MTQ Tarbiyah Sunnah" class="h-24 w-auto object-contain" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBr69pikY9oBaqc-AWrY3ZwuTZY9vDcnSYkZIpvverYEUcBdPJQ334QJLIUdr22tUZJ4z-BVT4YZcSSzQHnhz7YxliHOtFOzKl-SFLpZpKSsHxiWkgPZRZl8A6d4Kjql6a-IaNPNzMstRoe9OULfcEiuK8aNQnGKGkxR5A3otFY3tQ_B-A6kPOswDO1SCD-crRT9eN8CXb5Xzzt-TZVU4LoE6BLpUK4fAGNWrPdccHOC7wX-G3diH0d4Ehde3Y0k-iMpDwEyEx1wf0"/></div><h3 class="font-headline-md text-headline-md text-primary flex items-center gap-2"><span class="material-symbols-outlined">info</span> Tentang Ma'had</h3><p class="font-body-sm text-body-sm text-on-surface-variant leading-relaxed">Ma'had Tahfizhul Qur'an Tarbiyah Sunnah adalah lembaga pendidikan Islam yang berfokus pada pembentukan generasi penghafal Al-Qur'an yang bermanhaj Salafus Shalih, mengintegrasikan hafalan yang mutqin dengan pemahaman adab dan ilmu syar'i yang kokoh.</p></div></aside>
<!-- Article Grid - Desktop: Col 4-12, Mobile: Bottom -->
<div class="col-span-1 md:col-span-9 order-1 md:order-2 grid grid-cols-1 sm:grid-cols-2 gap-gutter">
{featuredArticle && (
<!-- Featured Article (Span 2 cols on desktop) -->
<article class="col-span-1 sm:col-span-2 bg-surface-container-lowest rounded-xl border border-surface-variant overflow-hidden hover:shadow-[0px_4px_20px_rgba(70,104,54,0.08)] hover:-translate-y-1 transition-all duration-300 flex flex-col md:flex-row">
<div class="md:w-1/2 h-64 md:h-auto bg-surface-container-highest relative">
<img alt={featuredArticle.data.title} class="w-full h-full object-cover" src={featuredArticle.data.coverImage || "https://lh3.googleusercontent.com/aida/AP1WRLsoN003K1-XgkIFAadcGIc_x4OqQfglK73QyUuWzQ_AoU-6NV4cND5wlnjA9OtY_zKW9HCHY93k3h6A6D9O4Rj15ZeqsnKHDkw-CzF5AdcnOSVqUU8oG5Y7Mh-6QrnwtY3qh2IVvqG35FcqE5XTVanWB38GpdjL4rpoHpvcE95vNomQ5OAdDxQ6BXAG5jaH-Oyw9tp6kSiMx_PPpZABrGccXgPojdireoBNSfu5FMn5Ia84WxPek7emIRg"}/>
<div class="absolute top-4 left-4">
<span class="bg-primary text-on-primary font-label-sm text-label-sm px-3 py-1 rounded-full shadow-sm">{featuredArticle.data.category || 'Artikel'}</span>
</div>
</div>
<div class="md:w-1/2 p-lg flex flex-col justify-center">
<div class="flex items-center gap-2 text-outline font-label-sm text-label-sm mb-sm">
<span class="material-symbols-outlined text-[16px]">calendar_today</span>
<time datetime={featuredArticle.data.date}>{new Date(featuredArticle.data.date).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
</div>
<h2 class="font-headline-lg text-headline-lg text-primary mb-md hover:text-secondary transition-colors cursor-pointer">
    <a href={`/artikel/${featuredArticle.id}`}>{featuredArticle.data.title}</a>
</h2>
<p class="font-body-md text-body-md text-on-surface-variant mb-lg line-clamp-3">{featuredArticle.data.summary}</p>
<a class="text-secondary font-label-lg text-label-lg flex items-center gap-2 hover:gap-3 transition-all w-fit" href={`/artikel/${featuredArticle.id}`}>
    Baca Selengkapnya <span class="material-symbols-outlined">arrow_forward</span>
</a>
</div>
</article>
)}

{regularArticles.map((article) => (
<!-- Regular Article Card -->
<article class="bg-surface-container-lowest rounded-xl border border-surface-variant overflow-hidden hover:shadow-[0px_4px_20px_rgba(70,104,54,0.08)] hover:-translate-y-1 transition-all duration-300 flex flex-col">
<div class="h-48 bg-surface-container-highest relative">
<img alt={article.data.title} class="w-full h-full object-cover" src={article.data.coverImage || "https://lh3.googleusercontent.com/aida/AP1WRLszwn5N-x9727cd7uNdMM0yrkccUouVYTKKXHz4avJ4m5djA1Avzj1uq8dK8cAPW5tOqSH1PevKcHlNgq56QuogIJm07ABO_8nP1LrmmtpR-E10w8X4KJWMnDVX27yrC_TmJqNH6tWSaIRBJiN7ow32uwgftGY6Tdw050Vp1w9ML0Cg2T1Z_y3pUBgJrD3BagRhLVFhKZ9-n9hYHmsTo8m0_qS12zapqP3D6giZtXSOySmabe31m4TLtKs"}/>
<div class="absolute top-4 left-4">
<span class="bg-surface-container-low text-primary font-label-sm text-label-sm px-3 py-1 rounded-full shadow-sm">{article.data.category || 'Artikel'}</span>
</div>
</div>
<div class="p-md flex flex-col flex-grow">
<div class="flex items-center gap-2 text-outline font-label-sm text-label-sm mb-sm">
<span class="material-symbols-outlined text-[16px]">calendar_today</span>
<time datetime={article.data.date}>{new Date(article.data.date).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
</div>
<h2 class="font-headline-md text-headline-md text-primary mb-sm hover:text-secondary transition-colors cursor-pointer line-clamp-2">
    <a href={`/artikel/${article.id}`}>{article.data.title}</a>
</h2>
<p class="font-body-md text-body-md text-on-surface-variant mb-md line-clamp-2 flex-grow">{article.data.summary}</p>
<a class="text-primary font-label-lg text-label-lg flex items-center gap-1 hover:text-secondary transition-colors w-fit mt-auto" href={`/artikel/${article.id}`}>
    Baca <span class="material-symbols-outlined text-[18px]">chevron_right</span>
</a>
</div>
</article>
))}

<!-- Pagination -->
<div class="col-span-1 sm:col-span-2 flex justify-center mt-lg pt-md border-t border-surface-variant">
<nav class="flex items-center gap-2">
<button class="p-2 rounded-lg text-outline hover:bg-surface-container hover:text-primary transition-colors" disabled="">
<span class="material-symbols-outlined">chevron_left</span>
</button>
<button class="w-10 h-10 rounded-lg bg-primary text-on-primary font-label-lg text-label-lg shadow-sm">1</button>
<button class="w-10 h-10 rounded-lg bg-surface text-on-surface hover:bg-surface-container transition-colors font-label-lg text-label-lg border border-surface-variant">2</button>
<button class="w-10 h-10 rounded-lg bg-surface text-on-surface hover:bg-surface-container transition-colors font-label-lg text-label-lg border border-surface-variant">3</button>
<span class="text-outline">...</span>
<button class="p-2 rounded-lg text-on-surface hover:bg-surface-container hover:text-primary transition-colors">
<span class="material-symbols-outlined">chevron_right</span>
</button>
</nav>
</div>
</div>
</main>
</Layout>
