---
import Layout from '../layouts/Layout.astro';
import pengaturanHalaman from '../content/pengaturanHalaman/data.json';
---

<Layout title="SPMB - MTQ Tarbiyah Sunnah">
<main class="flex-grow pt-[80px]">
<!-- Hero Section -->
<section class="relative pt-xl pb-lg px-margin-mobile md:px-margin-desktop overflow-hidden bg-surface-container-lowest border-b border-surface-variant">
<div class="absolute inset-0 pattern-bg opacity-50 z-0"></div>
<div class="max-w-7xl mx-auto relative z-10 grid grid-cols-1 md:grid-cols-2 gap-lg items-center">
<div>
<div class="inline-flex items-center gap-2 bg-surface-container-high px-sm py-xs rounded-full border border-surface-variant mb-md">
<span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
<span class="font-label-sm text-label-sm text-primary">Pendaftaran Dibuka - T.A 2024/2025</span>
</div>
<h1 class="font-display-lg text-display-lg text-on-surface mb-md">
    Sistem Penerimaan <br> <span class="text-primary">Murid Baru</span>
</h1>
<p class="font-body-lg text-body-lg text-on-surface-variant mb-lg max-w-lg">
    Bergabunglah bersama Ma'had Tahfizhul Qur'an Tarbiyah Sunnah. Mencetak generasi Qur'ani yang bermanhaj salafus shalih, berakhlak mulia, dan unggul dalam akademik.
</p>
<div class="flex flex-col sm:flex-row gap-md">
<button class="bg-secondary text-on-secondary font-label-lg text-label-lg px-lg py-sm rounded-lg hover:bg-secondary-container hover:text-on-secondary-container transition-all shadow-[0_4px_20px_rgba(149,74,0,0.2)] flex justify-center items-center gap-2">
    Daftar Sekarang
    <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
</button>
<a href="/hubungi-kami" class="border border-primary text-primary font-label-lg text-label-lg px-lg py-sm rounded-lg hover:bg-primary-container hover:text-on-primary-container transition-colors flex justify-center items-center gap-2">
    Konsultasi Admin
    <span class="material-symbols-outlined text-[18px]">chat</span>
</a>
</div>
</div>
<div class="hidden md:block relative h-[400px] rounded-xl overflow-hidden shadow-lg border border-surface-variant">
<img alt="Siswa belajar" class="w-full h-full object-cover" src={pengaturanHalaman.heroSpmb || "https://lh3.googleusercontent.com/aida-public/AB6AXuDSnJ1rELwyPcMK5jGXCCi64OO_mpGhJd-mxHg7ujV7Ut1PFDVwJMwr09Wbu9lnWT_qVPcuf59Y_E5ncnIqTyc8wv0p3dSMc3K0FXesaYMjr5qNB6v6nMZSa2oTgEiJ9_rIfVrlkELp3Bsi0JI6b1TEm_WOOXlAR60-gblkUn8y7Si8bCSgruoWmogsgRIVNnm6S8Ya4RYuyKUHgmMwgtR9GB5xFksu12HY-2W4qd1qAVxGNDO9Dl-0gJZjeZFovbpp4kUGD9YdDqg"}>
</div>
</div>
</section>
<!-- Alur Pendaftaran -->
<section class="py-xl px-margin-mobile md:px-margin-desktop bg-surface">
<div class="max-w-7xl mx-auto">
<div class="text-center mb-xl">
<h2 class="font-headline-lg text-headline-lg text-on-surface mb-sm">Alur Pendaftaran</h2>
<p class="font-body-md text-body-md text-on-surface-variant max-w-2xl mx-auto">
    Pahami langkah-langkah mudah untuk mendaftar sebagai santri baru di MTQ Tarbiyah Sunnah.
</p>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-md relative">
<!-- Connector Line (Desktop) -->
<div class="hidden lg:block absolute top-1/2 left-0 w-full h-[2px] bg-surface-variant -translate-y-1/2 z-0"></div>
<!-- Step 1 -->
<div class="relative z-10 bg-surface-container-lowest p-md rounded-xl border border-surface-variant shadow-sm hover:shadow-[0_4px_20px_rgba(70,104,54,0.08)] transition-all flex flex-col items-center text-center">
<div class="w-12 h-12 bg-primary-container text-on-primary-container rounded-full flex items-center justify-center font-headline-md text-headline-md mb-md border-4 border-surface">
    1
</div>
<h3 class="font-headline-md text-headline-md text-on-surface mb-xs">Informasi</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">Membaca brosur dan syarat pendaftaran secara seksama.</p>
</div>
<!-- Step 2 -->
<div class="relative z-10 bg-surface-container-lowest p-md rounded-xl border border-surface-variant shadow-sm hover:shadow-[0_4px_20px_rgba(70,104,54,0.08)] transition-all flex flex-col items-center text-center">
<div class="w-12 h-12 bg-surface-container-high text-on-surface rounded-full flex items-center justify-center font-headline-md text-headline-md mb-md border-4 border-surface">
    2
</div>
<h3 class="font-headline-md text-headline-md text-on-surface mb-xs">Formulir Online</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">Mengisi data diri melalui portal SPMB resmi.</p>
</div>
<!-- Step 3 -->
<div class="relative z-10 bg-surface-container-lowest p-md rounded-xl border border-surface-variant shadow-sm hover:shadow-[0_4px_20px_rgba(70,104,54,0.08)] transition-all flex flex-col items-center text-center">
<div class="w-12 h-12 bg-surface-container-high text-on-surface rounded-full flex items-center justify-center font-headline-md text-headline-md mb-md border-4 border-surface">
    3
</div>
<h3 class="font-headline-md text-headline-md text-on-surface mb-xs">Berkas</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">Mengunggah dokumen persyaratan yang dibutuhkan.</p>
</div>
<!-- Step 4 -->
<div class="relative z-10 bg-surface-container-lowest p-md rounded-xl border border-surface-variant shadow-sm hover:shadow-[0_4px_20px_rgba(70,104,54,0.08)] transition-all flex flex-col items-center text-center">
<div class="w-12 h-12 bg-surface-container-high text-on-surface rounded-full flex items-center justify-center font-headline-md text-headline-md mb-md border-4 border-surface">
    4
</div>
<h3 class="font-headline-md text-headline-md text-on-surface mb-xs">Seleksi</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">Mengikuti tes akademik dan kepesantrenan.</p>
</div>
<!-- Step 5 -->
<div class="relative z-10 bg-surface-container-lowest p-md rounded-xl border border-surface-variant shadow-sm hover:shadow-[0_4px_20px_rgba(70,104,54,0.08)] transition-all flex flex-col items-center text-center">
<div class="w-12 h-12 bg-surface-container-high text-on-surface rounded-full flex items-center justify-center font-headline-md text-headline-md mb-md border-4 border-surface">
    5
</div>
<h3 class="font-headline-md text-headline-md text-on-surface mb-xs">Wawancara</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">Sesi wawancara calon santri dan orang tua.</p>
</div>
<!-- Step 6 -->
<div class="relative z-10 bg-surface-container-lowest p-md rounded-xl border border-surface-variant shadow-sm hover:shadow-[0_4px_20px_rgba(70,104,54,0.08)] transition-all flex flex-col items-center text-center">
<div class="w-12 h-12 bg-surface-container-high text-on-surface rounded-full flex items-center justify-center font-headline-md text-headline-md mb-md border-4 border-surface">
    6
</div>
<h3 class="font-headline-md text-headline-md text-on-surface mb-xs">Pengumuman</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">Hasil seleksi diumumkan melalui portal dan email.</p>
</div>
<!-- Step 7 -->
<div class="relative z-10 bg-surface-container-lowest p-md rounded-xl border border-surface-variant shadow-sm hover:shadow-[0_4px_20px_rgba(70,104,54,0.08)] transition-all flex flex-col items-center text-center">
<div class="w-12 h-12 bg-secondary text-on-secondary rounded-full flex items-center justify-center font-headline-md text-headline-md mb-md border-4 border-surface">
    7
</div>
<h3 class="font-headline-md text-headline-md text-on-surface mb-xs">Daftar Ulang</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">Penyelesaian administrasi bagi yang lulus seleksi.</p>
</div>
</div>
</div>
</section>
</main>
</Layout>
