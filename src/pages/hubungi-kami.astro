---
import Layout from '../layouts/Layout.astro';
import pengaturanUtama from '../content/pengaturanUtama/data.json';
---

<Layout title="Kontak - MTQ Tarbiyah Sunnah">
<main class="flex-grow pt-[80px] pb-xl bg-surface-container-lowest">
<!-- Hero Section -->
<section class="relative bg-surface-container-low py-xl overflow-hidden">
<div class="absolute inset-0 bg-islamic-pattern pointer-events-none" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23466836' fill-opacity='0.05'%3E%3Cpath d='M30 0l15 15-15 15L15 15zM0 30l15-15 15 15-15 15zM30 60l15-15-15-15-15 15zM60 30l-15-15-15 15 15 15z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"></div>
<div class="max-w-7xl mx-auto px-margin-mobile md:px-margin-desktop relative z-10 text-center">
<h1 class="text-display-lg text-primary mb-sm">Hubungi Kami</h1>
<p class="text-body-lg text-on-surface-variant max-w-2xl mx-auto">Kami siap melayani pertanyaan dan memberikan informasi seputar Ma'had Tahfizhul Qur'an Tarbiyah Sunnah.</p>
</div>
</section>
<div class="max-w-7xl mx-auto px-margin-mobile md:px-margin-desktop py-lg">
<div class="grid grid-cols-1 lg:grid-cols-12 gap-lg">
<!-- Contact Info & Map -->
<div class="lg:col-span-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-md mb-lg">
<!-- Address Card -->
<div class="bg-surface-container-lowest border border-[#E9EEE7] rounded-xl p-md shadow-[0px_4px_20px_rgba(70,104,54,0.08)] hover:-translate-y-1 transition-transform duration-300">
<div class="flex items-start gap-sm mb-sm">
<div class="bg-surface-container w-10 h-10 rounded-full flex items-center justify-center text-primary flex-shrink-0">
<span class="material-symbols-outlined" data-icon="location_on">location_on</span>
</div>
<div>
<h3 class="text-headline-md text-primary mb-xs">Alamat Ma'had</h3>
<p class="text-body-md text-on-surface-variant">Desa Selacau, Kampung Lembur Tengah RT.01/ RW.05, Kec. Batujajar, Kab. Bandung Barat</p>
</div>
</div>
</div>
<!-- Visit Info Card -->
<div class="bg-surface-container border border-[#E9EEE7] rounded-xl p-md">
<div class="flex items-start gap-sm mb-sm">
<div class="bg-surface-container-lowest w-10 h-10 rounded-full flex items-center justify-center text-secondary flex-shrink-0">
<span class="material-symbols-outlined" data-icon="event_available">event_available</span>
</div>
<div>
<h3 class="text-headline-md text-secondary mb-xs">Informasi Kunjungan</h3>
<p class="text-body-md text-on-surface-variant mb-2">Untuk kenyamanan bersama, kunjungan ke Ma'had harus dikonfirmasi minimal <strong>H-1</strong> sebelum kedatangan.</p>
<div class="inline-block bg-secondary-fixed text-on-secondary-fixed text-label-sm px-3 py-1 rounded-full">
    Senin - Sabtu | 08:00 - 15:00 WIB
</div>
</div>
</div>
</div>
<!-- Map Placeholder -->
<a class="flex items-center gap-sm p-sm border border-[#E9EEE7] rounded-xl bg-surface-container-lowest hover:border-primary hover:shadow-[0px_4px_20px_rgba(70,104,54,0.08)] transition-all group" href="https://wa.me/6281210001476"><div class="w-12 h-12 bg-[#25D366] bg-opacity-10 rounded-full flex items-center justify-center text-[#25D366] group-hover:bg-[#25D366] group-hover:text-white transition-colors"><span class="material-symbols-outlined">chat</span></div><div><div class="text-label-sm text-on-surface-variant">WhatsApp Admin</div><div class="text-headline-md text-primary">+62 812 1000 1476</div></div></a>
<a class="flex items-center gap-sm p-sm border border-[#E9EEE7] rounded-xl bg-surface-container-lowest hover:border-primary hover:shadow-[0px_4px_20px_rgba(70,104,54,0.08)] transition-all group" href="mailto:info@tarbiyahsunnah.id"><div class="w-12 h-12 bg-primary bg-opacity-10 rounded-full flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-colors"><span class="material-symbols-outlined">mail</span></div><div><div class="text-label-sm text-on-surface-variant">Email Resmi</div><div class="text-headline-md text-primary" style="font-size: 18px; line-height: 24px;">info@tarbiyahsunnah.id</div></div></a></div>
<!-- Contact Form & Direct Links -->
<div class="lg:col-span-12 w-full"><div class="bg-surface-container-lowest border border-[#E9EEE7] rounded-xl overflow-hidden shadow-[0px_4px_20px_rgba(70,104,54,0.08)]"><div class="p-md border-b border-outline-variant flex justify-between items-center"><h2 class="text-headline-md text-primary">Lokasi Ma'had</h2><button class="bg-primary text-on-primary text-label-sm px-md py-1 rounded hover:bg-surface-tint transition-colors flex items-center gap-xs"><span class="material-symbols-outlined" style="font-size: 18px;">directions</span> Petunjuk Arah</button></div><div class="h-[500px] relative bg-surface-variant"><iframe allowfullscreen="" class="grayscale-[20%] contrast-[90%]" height="100%" loading="lazy" src={pengaturanUtama.googleMapsUrl} style="border:0;" width="100%"></iframe></div></div></div>
</div>
</div>
</main>
</Layout>
